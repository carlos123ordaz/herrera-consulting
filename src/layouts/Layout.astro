---
import '../styles/global.css';
interface Props {
  title: string;
  description: string;
  lang: 'es' | 'en';
}
const { title, description, lang } = Astro.props;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {lang === 'es' && (
    <script is:inline>
      if (!sessionStorage.getItem('lang-chosen')) {
        var l = (navigator.language || navigator.userLanguage || '').toLowerCase();
        if (!l.startsWith('es')) {
          sessionStorage.setItem('lang-chosen', 'en');
          location.replace('/en/');
        }
      }
    </script>
  )}
</head>
<body>
  <slot />

  <script is:inline>
    (function () {
      var EASE = "cubic-bezier(0.22, 0.61, 0.36, 1)";
      var reduced = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      window.__clockLive = false;

      function playReveal(el) {
        if (el.__shown) return;
        el.__shown = true;
        if (reduced || !el.animate || !window.__clockLive) return;
        var d = parseFloat(getComputedStyle(el).getPropertyValue("--d")) || 0;
        try {
          el.animate(
            [{ opacity: 0, transform: "translateY(36px)" }, { opacity: 1, transform: "none" }],
            { duration: 760, delay: d, easing: EASE, fill: "none" }
          );
        } catch (e) {}
        var marks = el.classList.contains("hl") ? [el] : el.querySelectorAll(".hl");
        marks.forEach(function (m) {
          var hd = parseFloat(getComputedStyle(m).getPropertyValue("--hd")) || 0.25;
          try {
            m.animate(
              [{ backgroundSize: "0% 100%" }, { backgroundSize: "0% 100%", offset: 0.0001 }, { backgroundSize: "104% 100%" }],
              { duration: 820, delay: d + hd * 1000, easing: EASE, fill: "none" }
            );
          } catch (e) {}
        });
      }

      function check() {
        var vh = window.innerHeight || document.documentElement.clientHeight;
        document.querySelectorAll("[data-reveal]").forEach(function (el) {
          if (el.__shown) return;
          var r = el.getBoundingClientRect();
          if (r.top < vh * 0.9 && r.bottom > 0) playReveal(el);
        });
      }
      window.__revealCheck = check;

      var ticking = false;
      var onScroll = function () {
        if (ticking) return; ticking = true;
        requestAnimationFrame(function () { ticking = false; check(); });
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll);

      try {
        var probe = document.createElement("div");
        probe.style.cssText = "position:fixed;left:-9999px;width:1px;height:1px;pointer-events:none;";
        document.body.appendChild(probe);
        var a = probe.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 1000 });
        setTimeout(function () {
          window.__clockLive = (a.currentTime || 0) > 0;
          try { a.cancel(); probe.remove(); } catch (e) {}
          check();
        }, 60);
      } catch (e) { window.__clockLive = false; check(); }
      setTimeout(check, 240);
      setTimeout(check, 600);

      /* Nav minimize on scroll */
      var nav = document.getElementById("site-nav");
      if (nav) {
        window.addEventListener("scroll", function () {
          nav.classList.toggle("is-min", window.scrollY > 560);
        }, { passive: true });
      }

      /* Parallax */
      if (!reduced) {
        var pticking = false;
        window.addEventListener("scroll", function () {
          if (pticking) return; pticking = true;
          requestAnimationFrame(function () {
            pticking = false;
            document.querySelectorAll("[data-parallax]").forEach(function (el) {
              var r = el.getBoundingClientRect();
              var speed = parseFloat(el.dataset.parallax) || 0.12;
              var center = r.top + r.height / 2 - window.innerHeight / 2;
              el.style.transform = "translate3d(0, " + (-center * speed).toFixed(1) + "px, 0)";
            });
          });
        }, { passive: true });
      }
    })();
  </script>
</body>
</html>
