---
import type { Translations } from '../i18n/types';
interface Props { t: Translations; }
const { t } = Astro.props;
const ft = t.footer;
---

<footer class="footer">
  <div class="footer__top">
    <div class="footer__brand">
      <a href="#top" class="brand" aria-label="Inicio">
        <span class="brand__dot"></span>
        <span><b>herrera</b><span class="light full"> consulting</span></span>
      </a>
      <p>{ft.tagline}</p>
      <div class="footer__social">
        <a href="#" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v6h-4v-6a2 2 0 0 0-4 0v6h-4v-10h4v1.5"/>
            <path d="M2 9h4v11H2z"/>
            <path d="M4 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/>
          </svg>
        </a>
        <a href="#" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12 12 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"/>
          </svg>
        </a>
        <a href="#" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5z"/>
            <path d="M12 8.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7z"/>
            <path d="M17.5 6.5h.01"/>
          </svg>
        </a>
      </div>
    </div>
    {ft.cols.map((col) => (
      <div class="footer__col">
        <h4>{col.h}</h4>
        {col.links.map((l) => <a href="#">{l}</a>)}
      </div>
    ))}
  </div>
  <div class="footer__bottom">
    <span>{ft.copy}</span>
    <span>{ft.madeWith}</span>
  </div>
</footer>
