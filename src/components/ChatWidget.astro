---
import type { Translations } from '../i18n/types';
interface Props { t: Translations; }
const { t } = Astro.props;
const ch = t.chat;

const WA_NUMBER = "573000000000";
const WA_PROJECTS = ["Web · eCommerce", "Software a medida", "App móvil", "Soluciones con IA", "Automatización / RPA", "Cloud & DevOps", "No estoy seguro"];
const WA_COUNTRIES = [
  { label: "PE (+51)", code: "51" }, { label: "CO (+57)", code: "57" }, { label: "MX (+52)", code: "52" },
  { label: "CL (+56)", code: "56" }, { label: "AR (+54)", code: "54" }, { label: "EC (+593)", code: "593" },
  { label: "ES (+34)", code: "34" }, { label: "US (+1)", code: "1" },
];
---

<!-- WhatsApp FAB -->
<button class="wa-fab" id="wa-fab" aria-label="Escríbenos por WhatsApp">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
    <path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9z"/>
    <path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/>
  </svg>
</button>

<!-- WhatsApp form -->
<div class="wa-form" id="wa-form" role="dialog" aria-label="Formulario de WhatsApp">
  <div class="wa-form__head">
    <span class="wa-form__logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9z"/>
        <path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/>
      </svg>
    </span>
    WhatsApp
    <button class="wa-form__close" id="wa-close" aria-label="Cerrar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <form class="wa-form__body" id="wa-form-inner">
    <h4>Completa con tus datos</h4>
    <p>¡Hola! Para poder atenderte necesitamos que nos brindes algunos datos.</p>
    <label class="wa-field">
      <span>Tu nombre</span>
      <input id="wa-name" placeholder="Escribe tu nombre" required />
    </label>
    <label class="wa-field">
      <span>N° de WhatsApp</span>
      <div class="wa-phone">
        <select id="wa-cc" aria-label="Código de país">
          {WA_COUNTRIES.map((c) => <option value={c.code}>{c.label}</option>)}
        </select>
        <input id="wa-phone" placeholder="987 654 321" inputmode="tel" required />
      </div>
    </label>
    <label class="wa-field">
      <span>¿Qué tipo de proyecto deseas?</span>
      <select id="wa-project">
        {WA_PROJECTS.map((p) => <option value={p}>{p}</option>)}
      </select>
    </label>
    <button type="submit" class="wa-form__cta">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9z"/>
        <path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/>
      </svg>
      Iniciar Chat
    </button>
    <div class="wa-form__foot">Te responderemos al instante</div>
  </form>
</div>

<!-- Chat FAB -->
<button class="chat-fab" id="chat-fab" aria-label={ch.fabLabel}>
  <span class="chat-fab__dot"></span>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 7V4"/><path d="M9 4h6"/>
    <path d="M5 9h14a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2z"/>
    <path d="M9 14h.01"/><path d="M15 14h.01"/>
  </svg>
</button>

<!-- Chat panel -->
<div class="chat-panel" id="chat-panel" role="dialog" aria-label={ch.dialogLabel}>
  <div class="chat-head">
    <div class="chat-head__avatar">CH</div>
    <div class="chat-head__info">
      <b>{ch.botName}</b>
      <span><i></i> {ch.botStatus}</span>
    </div>
    <button class="chat-head__close" id="chat-close" aria-label={ch.closeLabel}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <div class="chat-body" id="chat-body"></div>
  <div class="chat-chips" id="chat-chips">
    {ch.chips.map((chip) => (
      <button class="chip-btn" data-text={chip}>{chip}</button>
    ))}
  </div>
  <form class="chat-input" id="chat-form">
    <input type="text" id="chat-input" placeholder={ch.inputPlaceholder} autocomplete="off" />
    <button type="submit" id="chat-send" disabled aria-label="Enviar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4z"/>
      </svg>
    </button>
  </form>
  <div class="chat-disclaimer">{ch.disclaimer}</div>
</div>

<script define:vars={{ greeting: ch.greeting, scripted: ch.scripted, defaultReply: ch.defaultReply, WA_NUMBER }}>
  /* ---- WhatsApp FAB ---- */
  const waFab = document.getElementById('wa-fab');
  const waForm = document.getElementById('wa-form');
  const waClose = document.getElementById('wa-close');
  const waFormInner = document.getElementById('wa-form-inner');

  waFab.addEventListener('click', () => {
    const open = waForm.classList.toggle('is-open');
    waFab.classList.toggle('is-active', open);
    if (open) {
      waFab.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>`;
    } else {
      waFab.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9z"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/></svg>`;
    }
  });
  waClose.addEventListener('click', () => {
    waForm.classList.remove('is-open');
    waFab.classList.remove('is-active');
    waFab.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9z"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/></svg>`;
  });
  waFormInner.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = document.getElementById('wa-name').value || '(sin nombre)';
    const cc = document.getElementById('wa-cc').value;
    const phone = document.getElementById('wa-phone').value;
    const project = document.getElementById('wa-project').value;
    const msg = `¡Hola! Soy ${name}.%0AMe interesa: ${project}.%0AMi WhatsApp: +${cc} ${phone}`;
    window.open(`https://wa.me/${WA_NUMBER}?text=${msg}`, '_blank', 'noopener');
  });

  /* ---- Chat widget ---- */
  const chatFab = document.getElementById('chat-fab');
  const chatPanel = document.getElementById('chat-panel');
  const chatClose = document.getElementById('chat-close');
  const chatBody = document.getElementById('chat-body');
  const chipsEl = document.getElementById('chat-chips');
  const chatForm = document.getElementById('chat-form');
  const chatInput = document.getElementById('chat-input');
  const chatSend = document.getElementById('chat-send');

  function addMsg(text, from) {
    const el = document.createElement('div');
    el.className = `msg msg--${from}`;
    el.textContent = text;
    chatBody.appendChild(el);
    chatBody.scrollTop = chatBody.scrollHeight;
  }

  function showTyping() {
    const el = document.createElement('div');
    el.className = 'typing';
    el.innerHTML = '<i></i><i></i><i></i>';
    chatBody.appendChild(el);
    chatBody.scrollTop = chatBody.scrollHeight;
    return el;
  }

  function matchReply(text) {
    const t = text.toLowerCase();
    for (const s of scripted) {
      if (s.k.some(k => t.includes(k))) return s.a;
    }
    return defaultReply;
  }

  function send(text) {
    const t = text.trim();
    if (!t) return;
    chipsEl.style.display = 'none';
    addMsg(t, 'user');
    chatInput.value = '';
    chatSend.disabled = true;
    const typing = showTyping();
    const reply = matchReply(t);
    const delay = Math.min(2000, 700 + reply.length * 12);
    setTimeout(() => {
      typing.remove();
      addMsg(reply, 'bot');
    }, delay);
  }

  chatFab.addEventListener('click', () => {
    chatFab.classList.add('is-hidden');
    chatPanel.classList.add('is-open');
  });
  chatClose.addEventListener('click', () => {
    chatPanel.classList.remove('is-open');
    chatFab.classList.remove('is-hidden');
  });
  chatForm.addEventListener('submit', (e) => { e.preventDefault(); send(chatInput.value); });
  chatInput.addEventListener('input', () => { chatSend.disabled = !chatInput.value.trim(); });
  document.querySelectorAll('.chip-btn').forEach(btn => {
    btn.addEventListener('click', () => send(btn.dataset.text || ''));
  });

  addMsg(greeting, 'bot');
</script>
