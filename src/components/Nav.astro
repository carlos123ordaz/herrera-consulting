---
import type { Translations } from '../i18n/types';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<header class="nav" id="site-nav">
  <div class="container nav__inner">
    <a href="#top" class="brand">
      <span class="brand__mark"><span></span></span>
      <span>
        {t.brand.name}
        <small>{t.brand.tagline}</small>
      </span>
    </a>
    <nav class="nav__links">
      {t.nav.links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <div class="nav__cta">
      <div class="lang-switch">
        <a href="/" class={t.lang === 'es' ? 'is-active' : ''}>ES</a>
        <a href="/en/" class={t.lang === 'en' ? 'is-active' : ''}>EN</a>
      </div>
      <a href="#contacto" class="btn btn--primary btn--sm">{t.nav.cta}</a>
      <button class="nav__burger" id="burger-btn" aria-label="Menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="burger-icon">
          <path d="M3 6h18M3 12h18M3 18h18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu">
  {t.nav.links.map((l) => <a href={l.href}>{l.label}</a>)}
  <a href="#contacto" class="btn btn--primary">{t.nav.cta}</a>
  <div class="lang-switch">
    <a href="/" class={t.lang === 'es' ? 'is-active' : ''}>ES</a>
    <a href="/en/" class={t.lang === 'en' ? 'is-active' : ''}>EN</a>
  </div>
</div>

<script>
  const nav = document.getElementById('site-nav')!;
  const burger = document.getElementById('burger-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const icon = document.getElementById('burger-icon')!;

  const menuIcon = `<path d="M3 6h18M3 12h18M3 18h18"/>`;
  const closeIcon = `<path d="M18 6L6 18M6 6l12 12"/>`;

  window.addEventListener('scroll', () => {
    nav.classList.toggle('is-scrolled', window.scrollY > 24);
  }, { passive: true });

  burger.addEventListener('click', () => {
    const open = menu.classList.toggle('is-open');
    icon.innerHTML = open ? closeIcon : menuIcon;
  });

  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.remove('is-open');
      icon.innerHTML = menuIcon;
    });
  });
</script>
