---
import type { Translations } from '../i18n/types';
interface Props { t: Translations; }
const { t } = Astro.props;
const p = t.process;
---

<section class="process" id="proceso">
  <div class="process__head">
    <span class="eyebrow" data-reveal>{p.eyebrow}</span>
    <h2 data-reveal style="--d:60ms">
      Un proceso claro, <span class="serif">sin cajas negras.</span>
    </h2>
  </div>
  <div class="steps">
    {p.steps.map((step, i) => (
      <div class="step" data-reveal style={`--d:${i * 90}ms`}>
        <div class="step__num">{step.num} / 0{p.steps.length}</div>
        <h3>{step.title}</h3>
        <p>{step.desc}</p>
      </div>
    ))}
  </div>
</section>
