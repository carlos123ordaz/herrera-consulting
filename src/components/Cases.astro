---
import type { Translations } from '../i18n/types';
interface Props { t: Translations; }
const { t } = Astro.props;
const c = t.cases;

const items = c.items.slice(0, 3);
const caseImages = [
  '/images/case-finvex.jpg',
  '/images/case-agrosur.jpg',
  '/images/case-meditrack.jpg',
];
---

<section class="portfolio" id="casos">
  <div class="portfolio__head">
    <h2 data-reveal>Nuestros<br />casos</h2>
    <span class="arrow-down" data-reveal style="--d:120ms">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 4v15M6 13l6 6 6-6"/>
      </svg>
    </span>
  </div>
  <div class="cases">
    {items.map((item, i) => (
      <article class="case-row" data-reveal>
        <div class="case-row__media">
          <img src={caseImages[i]} alt={item.title} class="case-row__img" loading="lazy" width="800" height="450" />
          <a href="#contacto" class="case-row__cta">Ver proyecto</a>
        </div>
        <div class="case-row__body">
          <span class="case-row__cat">{item.cat}</span>
          <h3>{item.title}</h3>
          <p>{item.desc}</p>
          <div class="case-row__metrics">
            {item.metrics.map((m) => (
              <div class="case-row__metric">
                <b>{m[0]}</b>
                <span>{m[1]}</span>
              </div>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
