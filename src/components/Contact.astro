---
import type { Translations } from '../i18n/types';
interface Props { t: Translations; }
const { t } = Astro.props;
const c = t.contact;
const f = c.form;
const svcTitles = t.services.items.map(s => s.title);

const ICONS: Record<string, string> = {
  mail: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><path d="M2 7l10 6 10-6"/></svg>`,
  whatsapp: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9z"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/></svg>`,
  clock: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z"/><path d="M12 7v5l3 2"/></svg>`,
  check: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>`,
  arrowRight: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>`,
};
---

<section class="section contact" id="contacto">
  <div class="contact__glow"></div>
  <div class="container contact__layout">
    <div class="contact__left reveal">
      <span class="eyebrow eyebrow--on-navy">{c.eyebrow}</span>
      <h2 class="h-section" style="margin-top:20px">{c.title}</h2>
      <p class="lead">{c.lead}</p>
      <div class="contact__points">
        {c.points.map((pt) => (
          <div class="contact__point">
            <div class="contact__point-ic" set:html={ICONS[pt.icon]}></div>
            <div>
              <b>{pt.title}</b>
              <span>{pt.sub}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal">
      <form class="form" id="contact-form" novalidate>
        <div id="form-fields">
          <div class="form__row">
            <div class="field" id="field-name">
              <label for="inp-name">{f.name} *</label>
              <input id="inp-name" type="text" placeholder={f.namePlaceholder} />
              <div class="field__err" style="display:none">{f.required}</div>
            </div>
            <div class="field" id="field-email">
              <label for="inp-email">{f.email} *</label>
              <input id="inp-email" type="email" placeholder={f.emailPlaceholder} />
              <div class="field__err" style="display:none">{f.required}</div>
            </div>
          </div>
          <div class="field">
            <label for="inp-company">{f.company}</label>
            <input id="inp-company" type="text" placeholder={f.companyPlaceholder} />
          </div>
          <div class="field">
            <label for="inp-service">{f.service}</label>
            <select id="inp-service">
              <option value="">{f.servicePlaceholder}</option>
              {svcTitles.map((title) => <option value={title}>{title}</option>)}
              <option value="other">{f.serviceOther}</option>
            </select>
          </div>
          <div class="field" id="field-message">
            <label for="inp-message">{f.message} *</label>
            <textarea id="inp-message" placeholder={f.messagePlaceholder}></textarea>
            <div class="field__err" style="display:none">{f.messageRequired}</div>
          </div>
          <button type="submit" class="btn btn--primary">
            {f.submit}
            <span set:html={ICONS.arrowRight}></span>
          </button>
        </div>

        <div id="form-success" style="display:none" class="form__success">
          <div class="form__success-ic" set:html={ICONS.check}></div>
          <h3>{f.successTitle}</h3>
          <p id="success-msg"></p>
        </div>
      </form>
    </div>
  </div>
</section>

<script define:vars={{ invalidEmail: f.invalidEmail, required: f.required, messageRequired: f.messageRequired, successMessage: f.successMessage }}>
  const form = document.getElementById('contact-form');
  const fields = document.getElementById('form-fields');
  const success = document.getElementById('form-success');
  const successMsg = document.getElementById('success-msg');

  function showErr(fieldId, msg) {
    const field = document.getElementById(fieldId);
    field.classList.add('field--error');
    const err = field.querySelector('.field__err');
    if (err) { err.textContent = msg; err.style.display = 'block'; }
  }
  function clearErr(fieldId) {
    const field = document.getElementById(fieldId);
    field.classList.remove('field--error');
    const err = field.querySelector('.field__err');
    if (err) err.style.display = 'none';
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = document.getElementById('inp-name').value.trim();
    const email = document.getElementById('inp-email').value.trim();
    const message = document.getElementById('inp-message').value.trim();
    let valid = true;

    clearErr('field-name'); clearErr('field-email'); clearErr('field-message');

    if (!name) { showErr('field-name', required); valid = false; }
    if (!email) { showErr('field-email', required); valid = false; }
    else if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) { showErr('field-email', invalidEmail); valid = false; }
    if (!message) { showErr('field-message', messageRequired); valid = false; }

    if (valid) {
      successMsg.textContent = successMessage.replace('{name}', name.split(' ')[0] || '👋');
      fields.style.display = 'none';
      success.style.display = 'block';
    }
  });
</script>
