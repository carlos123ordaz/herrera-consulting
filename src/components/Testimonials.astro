---
import type { Translations } from '../i18n/types';
interface Props { t: Translations; }
const { t } = Astro.props;
const testi = t.testimonials;

const AVATARS = [
  '/images/avatar-maria.jpg',
  '/images/avatar-daniel.jpg',
  '/images/avatar-lucia.jpg',
];

const arrowLeft = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>`;
const arrowRight = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>`;
const starIcon = `<svg viewBox="0 0 24 24" fill="currentColor" stroke="none" style="width:18px;height:18px"><path d="M12 3l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 18l-5.9 3 1.2-6.5L2.5 9.9 9.1 9z"/></svg>`;
---

<section class="section testi">
  <div class="container">
    <div class="section-head center reveal">
      <span class="eyebrow eyebrow--center">{testi.eyebrow}</span>
      <h2 class="h-section">{testi.title}</h2>
    </div>

    <div class="testi__stage" id="testi-stage">
      {testi.items.map((item, idx) => (
        <div class={`tcard ${idx === 0 ? 'is-active' : ''}`} data-idx={idx}>
          <div style="display:flex;justify-content:center;gap:4px;margin-bottom:26px;color:var(--accent)">
            {[0,1,2,3,4].map(() => <span set:html={starIcon}></span>)}
          </div>
          <p class="tcard__quote">
            {item.quote[0]}<span>{item.quote[1]}</span>{item.quote[2]}
          </p>
          <div class="tcard__author">
            <img
              src={AVATARS[idx]}
              alt={item.name}
              class="tcard__avatar"
              loading="lazy"
              width="52"
              height="52"
            />
            <div class="tcard__author-info">
              <b>{item.name}</b>
              <span>{item.role}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="testi__nav">
      <button class="testi__arrow" id="testi-prev" aria-label="Previous" set:html={arrowLeft}></button>
      <div class="testi__dots" id="testi-dots">
        {testi.items.map((_, idx) => (
          <button class={idx === 0 ? 'is-active' : ''} data-idx={idx} aria-label={`Testimonial ${idx + 1}`}></button>
        ))}
      </div>
      <button class="testi__arrow" id="testi-next" aria-label="Next" set:html={arrowRight}></button>
    </div>
  </div>
</section>

<style>
  .tcard__avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
    object-position: top center;
    border: 2px solid var(--hairline);
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.tcard');
  const dots = document.querySelectorAll<HTMLElement>('#testi-dots button');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function go(idx: number) {
    cards[current].classList.remove('is-active');
    dots[current].classList.remove('is-active');
    current = (idx + cards.length) % cards.length;
    cards[current].classList.add('is-active');
    dots[current].classList.add('is-active');
  }

  function startTimer() {
    clearInterval(timer);
    timer = setInterval(() => go(current + 1), 7000);
  }

  document.getElementById('testi-prev')!.addEventListener('click', () => { go(current - 1); startTimer(); });
  document.getElementById('testi-next')!.addEventListener('click', () => { go(current + 1); startTimer(); });
  dots.forEach((dot, idx) => dot.addEventListener('click', () => { go(idx); startTimer(); }));
  startTimer();
</script>
